# Optional — InfraPilot runs fully without these.
# Set to enable LLM reasoning (anomaly triage + remediation rationale).
ANTHROPIC_API_KEY=

# Override the model used by the LLM layer / CrewAI engine.
# native/llm layer default: claude-sonnet-4-6
# crewai engine default:    anthropic/claude-sonnet-4-6
INFRAPILOT_MODEL=
